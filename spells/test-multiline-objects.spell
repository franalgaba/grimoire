# Test: multi-line object literals in expression context
# Note: object literals are parsed successfully; downstream IR support depends on venue adapters

spell TestMultilineObjects {

  version: "1.0.0"
  description: "Object literals can span multiple lines"

  assets: [USDC]

  params: {
    cfg: {
      session_id: "test-session-1"
      v: 1
      quorum: 1
    }

  }
  venues: {
    venue: @uniswap_v3

  }
  on manual: {
    venue.swap(USDC, USDC, params.cfg.v)
    emit done(status=1)

  }
}
