# Test: extended action constraints

spell TestConstraintsExtended {

  version: "1.0.0"
  description: "Action constraints with additional fields"

  assets: [USDC, ETH]

  params: {
    amount: 100000

  }
  venues: {
    uniswap_v3: @uniswap_v3

  }
  on manual: {
    uniswap_v3.swap(USDC, ETH, params.amount) with (
      slippage=50,
      deadline=300,
      min_output=1,
      max_input=200000,
      require_quote=true,
    )
    emit constraints_applied(amount=params.amount)

  }
}
