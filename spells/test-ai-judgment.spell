# Test: AI judgment — advisory binding for swap decision

spell TestAIJudgment {

  version: "1.0.0"
  description: "Use AI advisory to decide whether to execute a swap"
  assets: [ETH, USDC]

  advisors: {
    market_analyst: {
      model: "openai-codex:gpt-5.2-codex"
    }
  }
  params: {
    amount: 200000000000000
    price_threshold: 3000

  }
  venues: {
    uniswap_v4: @uniswap_v4

  }
  on manual: {
    decision = advise market_analyst: "should we swap ETH to USDC given current market conditions" {
      output: {
        type: boolean
      }
      timeout: 30
      fallback: true
    }
    if decision {
      uniswap_v4.swap(ETH, USDC, params.amount)
      emit ai_approved_swap(amount=params.amount)
    } else {
      emit ai_rejected_swap(reason="advisory_declined")

    }
  }
}
